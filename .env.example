# Project Borg — Environment Variables
# Copy to .env and fill in real values.

# Database (for local docker-compose)
POSTGRES_PASSWORD=borg_password
DATABASE_URL=postgresql+asyncpg://borg:borg_password@borg-db:5432/borg
DATABASE_URL_SYNC=postgresql://borg:borg_password@borg-db:5432/borg

# OpenAI (default — required unless Azure OpenAI is configured below)
OPENAI_API_KEY=sk-your-key-here
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

# Optional: Azure OpenAI (leave empty to use standard OpenAI)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
AZURE_OPENAI_EXTRACTION_DEPLOYMENT=gpt-5-mini

# App surface
BORG_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
BORG_ENABLE_DOCS=true
BORG_PUBLIC_BASE_URL=http://localhost:8080

# Logging
LOG_LEVEL=INFO
